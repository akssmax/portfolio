# Sanity CMS — copy to .env.local and fill in your project values
# Create a project at https://sanity.io/manage

VITE_SANITY_PROJECT_ID=
VITE_SANITY_DATASET=production

# Optional: for seed script and draft preview
SANITY_API_WRITE_TOKEN=

# Mistral AI — server-only (never prefix with VITE_)
# Required for /api/chat and npm run build:rag
MISTRAL_API_KEY=
MISTRAL_CHAT_MODEL=mistral-small-latest
MISTRAL_EMBED_MODEL=mistral-embed

# Optional: cap upstream chat timeout on Vercel (milliseconds)
# VERCEL_CHAT_TIMEOUT_MS=55000

# Private resume builder at /resume (server-only — never prefix with VITE_)
RESUME_BUILDER_SECRET=

# Brave Search API — server-only (never prefix with VITE_)
# Free tier: https://api-dashboard.search.brave.com/
BRAVE_SEARCH_API_KEY=
